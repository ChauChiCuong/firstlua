local RUNTIME_KEY = "__CuongOutLookRuntime"
local runtimeEnv = (type(getgenv) == "function" and getgenv()) or _G
local previousRuntime = runtimeEnv[RUNTIME_KEY]
if type(previousRuntime) == "table" then
    previousRuntime.alive = false
    if type(previousRuntime.cleanup) == "function" then
        pcall(previousRuntime.cleanup)
    end
end

local RUNTIME = {
    alive = true,
    cleaned = false,
    connections = {},
    drawings = {},
}
runtimeEnv[RUNTIME_KEY] = RUNTIME

local function isRuntimeAlive()
    return RUNTIME.alive == true and runtimeEnv[RUNTIME_KEY] == RUNTIME
end

local function trackConnection(conn)
    if conn then
        RUNTIME.connections[#RUNTIME.connections + 1] = conn
    end
    return conn
end

local function bindTracked(signal, fn)
    local conn
    conn = signal:Connect(function(...)
        if not isRuntimeAlive() then
            pcall(function()
                if conn then conn:Disconnect() end
            end)
            return
        end
        return fn(...)
    end)
    return trackConnection(conn)
end

local function registerDrawing(obj)
    if obj then
        RUNTIME.drawings[#RUNTIME.drawings + 1] = obj
    end
    return obj
end

local function cleanupRuntime()
    if RUNTIME.cleaned then return end
    RUNTIME.cleaned = true
    RUNTIME.alive = false

    for i = #RUNTIME.connections, 1, -1 do
        local conn = RUNTIME.connections[i]
        pcall(function()
            if conn then conn:Disconnect() end
        end)
        RUNTIME.connections[i] = nil
    end

    for i = #RUNTIME.drawings, 1, -1 do
        local obj = RUNTIME.drawings[i]
        pcall(function()
            if obj and obj.Remove then
                obj:Remove()
            elseif obj and obj.Destroy then
                obj:Destroy()
            end
        end)
        RUNTIME.drawings[i] = nil
    end

    local function destroyNamedGui(guiName)
        if not guiName or guiName == "" then return end
        local hui = safeGetHui()
        if hui then
            local found = hui:FindFirstChild(guiName)
            if found then
                pcall(function() found:Destroy() end)
            end
        end
        local playerGui = plr and plr:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            local found = playerGui:FindFirstChild(guiName)
            if found then
                pcall(function() found:Destroy() end)
            end
        end
    end

    destroyNamedGui("cuongoutlookUndetect")
    destroyNamedGui("CuongOutLookNotify")
    destroyNamedGui("CuongOutLookMobileFOV")

    if STATE then
        pcall(function() STATE._stopMenuBackgroundFx() end)
        pcall(function() STATE._bhRestoreAll() end)
        pcall(function()
            if STATE._camlockStepConn then STATE._camlockStepConn:Disconnect(); STATE._camlockStepConn = nil end
            if STATE._menuFxConn then STATE._menuFxConn:Disconnect(); STATE._menuFxConn = nil end
            if STATE._menuFlameConn then STATE._menuFlameConn:Disconnect(); STATE._menuFlameConn = nil end
            if STATE._collapsedFxConn then STATE._collapsedFxConn:Disconnect(); STATE._collapsedFxConn = nil end
            if STATE._fovFlushConn then STATE._fovFlushConn:Disconnect(); STATE._fovFlushConn = nil end
            if STATE._screenFxConn then STATE._screenFxConn:Disconnect(); STATE._screenFxConn = nil end
            if STATE._triggerHeld then safeMouse1Release(); STATE._triggerHeld = false end
        end)
        pcall(function()
            if STATE._aimFOVCircle then STATE._aimFOVCircle.Visible = false end
            if STATE._camlockMobileFOVCircle then STATE._camlockMobileFOVCircle.Visible = false end
        end)
    end
end
