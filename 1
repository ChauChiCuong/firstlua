local function readCachedUrl(metaFile)
    if type(metaFile) ~= "string" or metaFile == "" then return nil end
    if type(isfile) ~= "function" or type(readfile) ~= "function" then return nil end
    local okExists, exists = pcall(isfile, metaFile)
