local function addNormalizedId(target, value)
    local idText = normalizeIdText(value)
    if idText then
        target[idText] = true
    end
end

local function collectBannedIdsFromValue(value, bannedIds)
    if type(value) ~= "table" then
        return
    end

    for key, item in pairs(value) do
        if type(item) == "number" or type(item) == "string" then
            addNormalizedId(bannedIds, item)
        elseif type(item) == "table" then
            collectBannedIdsFromValue(item, bannedIds)
        end

        if type(key) == "number" then
            addNormalizedId(bannedIds, key)
        end
    end
end

local function collectNamedBannedIds(sourceTable, keyNames, bannedIds)
    for _, keyName in ipairs(keyNames) do
        local value = sourceTable[keyName]
        if type(value) == "table" then
            collectBannedIdsFromValue(value, bannedIds)
        elseif type(value) == "number" or type(value) == "string" then
            addNormalizedId(bannedIds, value)
        end
    end
end

local function parseBannedGameIds(rawText)
    local parsed = {
        all = {},
        placeIds = {},
        gameIds = {}
    }

    local okLoad, chunk = pcall(function()
        return loadstring(rawText)
    end)
    if okLoad and type(chunk) == "function" then
        local okResult, result = pcall(chunk)
        if okResult and type(result) == "table" then
            collectBannedIdsFromValue(result, parsed.all)
            collectNamedBannedIds(result, {"placeIds", "placeids", "places", "placeId", "placeid"}, parsed.placeIds)
            collectNamedBannedIds(result, {"gameIds", "gameids", "games", "gameId", "gameid", "experienceIds", "experienceids"}, parsed.gameIds)
        end
    end

    for idText in rawText:gmatch("%d+") do
        parsed.all[idText] = true
    end

    return parsed
end

local function isCurrentGameBanned()
    local okFetch, rawText = pcall(function()
        return game:HttpGet(BANNED_GAME_ID_SOURCE_URL)
    end)
    if not okFetch or type(rawText) ~= "string" or rawText == "" then
        return false, "Không thể tải danh sách game bị chặn."
    end

    local bannedIds = parseBannedGameIds(rawText)

    if next(bannedIds.all) == nil and next(bannedIds.placeIds) == nil and next(bannedIds.gameIds) == nil then
        return false, "Danh sách game bị chặn không hợp lệ."
    end

    local placeId = normalizeIdText(game.PlaceId) or tostring(game.PlaceId)
    local gameId = normalizeIdText(game.GameId) or tostring(game.GameId)
    local placeBlocked = bannedIds.placeIds[placeId] == true or bannedIds.all[placeId] == true
    local gameBlocked = bannedIds.gameIds[gameId] == true or bannedIds.all[gameId] == true
    return placeBlocked or gameBlocked, nil
end

local function disconnectForBannedGame(reason)
    terminated = true

    pcall(function()
        if screenGui and screenGui.Parent then
            screenGui:Destroy()
        end
    end)

    for _ = 1, 3 do
        local okKick = pcall(function()
            localPlayer:Kick(reason)
        end)
        if okKick then
            task.wait(0.2)
        end

        local okDisconnect = false
        if NetworkClient then
            okDisconnect = pcall(function()
                NetworkClient:Disconnect(reason)
            end)
        end
        if okDisconnect then
            task.wait(0.2)
        end
    end

    error(reason, 0)
end

local function onValid(key)
    if terminated then return end
    -- Xóa khoảng trắng thừa nếu copy nhầm
    local cleanKey = normalizeKeyInput(key)
    if not cleanKey then
        warn("Key không hợp lệ.")
        return
    end

    local isBannedGame, bannedCheckErr = isCurrentGameBanned()
    if isBannedGame then
        disconnectForBannedGame(getUiText("bannedGameKickReason"))
        return
    end
    if bannedCheckErr then
        warn(bannedCheckErr)
    end
    
    getgenv().SCRIPT_KEY = cleanKey
    saveKey(cleanKey)
    
    -- Xóa giao diện Loader
    screenGui:Destroy()
    
    -- Đợi 1 chút cho an toàn
    task.wait(0.5)
    
    local selectedScript = SCRIPT_OPTIONS[1]
    local hasUrl = selectedScript and type(selectedScript.url) == "string" and selectedScript.url ~= ""
    local hasRun = selectedScript and type(selectedScript.run) == "function"
    if not selectedScript or (not hasUrl and not hasRun) then
        warn("Không tìm thấy script hợp lệ để tải.")
        return
    end

    print("Đang tải script: " .. tostring(selectedScript.name))
    
    -- ==========================================
    -- ĐÂY LÀ NƠI DUY NHẤT ĐƯỢC ĐỂ LỆNH LOADSTRING
    -- Thay link raw script của bạn vào đây:
    local okLoad, loadErr = pcall(function()
        if hasRun then
            selectedScript.run()
        else
            loadstring(game:HttpGet(selectedScript.url))()
        end
    end)
    if not okLoad then
        warn("Load script thất bại: " .. tostring(loadErr))
    end
    -- ==========================================
end

