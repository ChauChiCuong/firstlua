function STATE._getAutoChatLines(raw)
    local source = type(raw) == "string" and raw or ""
    local lines = {}
    for line in source:gmatch("[^\r\n]+") do
        local clean = line:match("^%s*(.-)%s*$")
        if clean and clean ~= "" then
            lines[#lines + 1] = clean
        end
    end
    return lines
end
function STATE._pickAutoChatMessage(raw)
    local lines = STATE._getAutoChatLines(raw)
    if #lines == 0 then
        return ""
    end
    if #lines == 1 then
        return lines[1]
    end
    local nextIndex
    repeat
        nextIndex = math.random(1, #lines)
    until nextIndex ~= tonumber(STATE._autoChatLastLineIndex)
    STATE._autoChatLastLineIndex = nextIndex
    return lines[nextIndex]
end
function STATE._sendAutoChatMessage(msg)
    local txt = STATE._pickAutoChatMessage(msg)
    if txt == "" then
        return false
    end

    local sent = false
    local okText, textChatService = pcall(function()
        return game:GetService("TextChatService")
    end)
    if okText and textChatService and textChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local textChannels = textChatService:FindFirstChild("TextChannels")
        local general = textChannels and textChannels:FindFirstChild("RBXGeneral")
        if general then
            local okSend = pcall(function()
                general:SendAsync(txt)
            end)
            sent = okSend or sent
        end
    end

    if not sent then
        local okLegacy, legacySent = pcall(function()
            local events = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            local say = events and events:FindFirstChild("SayMessageRequest")
            if say then
                say:FireServer(txt, "All")
                return true
            end
            return false
        end)
        sent = (okLegacy and legacySent) or sent
    end

    if not sent then
        STATE._chatSend(txt)
        sent = true
    end
    return sent
end
function STATE._normalizeAutoChatSendKey(raw)
    local key = (type(raw) == "string" and raw:upper():gsub("%s+", ""):gsub("_", "")) or "NONE"
    if key == "" or key == "NONE" or key == "CLEAR" then
        return "NONE"
    end
    if key == "MOUSEBUTTON1" or key == "MOUSELEFT" or key == "LEFTMOUSE" or key == "LMB" then
        return "LMB"
    end
    if key == "MOUSEBUTTON2" or key == "MOUSERIGHT" or key == "RIGHTMOUSE" or key == "RMB" then
        return "RMB"
    end
    if key == "ESC" or key == "ESCAPE" then
        return "NONE"
    end
    if Enum.KeyCode[key] then
        return key
    end
    return nil
end
function STATE._autoChatSendKeyLabel()
    local key = STATE._normalizeAutoChatSendKey(STATE.autoChatSendKey) or "NONE"
