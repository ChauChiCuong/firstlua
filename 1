        if src == "" then return nil end
        if src == "RMB" or src == "MOUSEBUTTON2" or src == "MOUSERIGHT" or src == "RIGHTMOUSE" then
            return "RMB"
        elseif src == "LMB" or src == "MOUSEBUTTON1" or src == "MOUSELEFT" or src == "LEFTMOUSE" then
