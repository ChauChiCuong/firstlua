local function mobileRestoreCharacterTurn()
    local hum = getHum()
    if hum and STATE._camlockMobileAutoRotateSaved ~= nil then
        hum.AutoRotate = STATE._camlockMobileAutoRotateSaved
    end
    STATE._camlockMobileAutoRotateSaved = nil
