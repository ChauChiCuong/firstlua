bindTracked(RunService.RenderStepped, function(dt)
    if not STATE.esp then
        if next(espData) then clearAllESP() end
        return
    end
    local espInterval = 0.066
    STATE._espAccum = STATE._espAccum + dt
    if STATE._espAccum < espInterval then return end
    STATE._espAccum = 0
    STATE._espFrame = STATE._espFrame + 1
    local doSlow = (STATE._espFrame % 3 == 0)
    local cam    = Camera
    local seen = {}
    local controlledModels = {}
    local function processTarget(c, ownerPlayer, allowNoHumanoid)
        if not c or c == getChar() then return end
        local targetModel, hum = STATE._resolveTargetModel(c)
        if not targetModel or targetModel == getChar() then return end
        local resolvedOwner = ownerPlayer or STATE._getOwnerFromModel(targetModel)
        local hrp = espGetTrackingPart(targetModel)
        if ((not allowNoHumanoid) and (not hum or hum.Health <= 0)) or (hum and hum.Health <= 0) or not hrp then
            if espData[c] then destroyESP(c) end
            return
        end
        seen[c] = true
        if not espData[c] then createESP(c) end
        local e   = espData[c]
        local col = espCol(resolvedOwner)
        -- Chams (Highlight)
        if espShouldShowChams(resolvedOwner) then
            if not e.cham.Parent or e.cham.Parent ~= getESPContainer() then
                e.cham.Parent = getESPContainer()
            end
            e.cham.Enabled = true
            e.cham.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            if e.cham.Adornee ~= targetModel then
                e.cham.Adornee = targetModel
            end
            e.cham.OutlineColor = col
            e.cham.FillColor    = col
        else
            e.cham.Enabled = false
            if e.cham.Parent then e.cham.Parent = nil end
            e.cham.Adornee = nil
        end
        -- keep slow branch for timing symmetry; hp bar was removed
        if doSlow and hum then
            local _ = hum.Health
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr then
            processTarget(p.Character, p)
            local controlledModel = espGetControlledModel(p)
            if controlledModel then
                controlledModels[controlledModel] = true
                processTarget(controlledModel, p, true)
            end
        end
    end
    STATE._espNpcScanAccum = STATE._espNpcScanAccum + espInterval
    if STATE._espNpcScanAccum >= 0.5 or #(STATE._espNpcModels or {}) == 0 then
        STATE._espNpcScanAccum = 0
        STATE._espNpcModels = STATE._refreshNpcCache()
    end
    for _, model in ipairs(STATE._espNpcModels) do
        if not controlledModels[model] then
            processTarget(model, nil)
        end
    end
    for _, model in ipairs(STATE._getConfigTargetModels()) do
        local ownerPlayer = Players:GetPlayerFromCharacter(model)
        if model ~= getChar() and not controlledModels[model] then
            processTarget(model, ownerPlayer, true)
        end
    end
    for p in pairs(espData) do
        if not p.Parent or not seen[p] then destroyESP(p) end
    end
end)
