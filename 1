function STATE._updateMenuSweepGeometry()
    local layer = STATE._menuSweepLayer
    if not layer then return end
    local inset = math.max(0, tonumber(STATE._menuSweepInset) or 0)
    local baseCorner = math.max(0, tonumber(STATE._menuCornerRadius) or MENU_CORNER_RADIUS)
    layer.Position = UDim2.fromOffset(0, 0)
    layer.Size = UDim2.new(1, 0, 1, 0)
    if STATE._menuSweepCorner then
        STATE._menuSweepCorner.CornerRadius = UDim.new(0, baseCorner)
    end
    if STATE._menuSweepMask then
        STATE._menuSweepMask.Position = UDim2.fromOffset(inset, inset)
        STATE._menuSweepMask.Size = UDim2.new(1, -(inset * 2), 1, -(inset * 2))
    end
    if STATE._menuSweepMaskCorner then
        STATE._menuSweepMaskCorner.CornerRadius = UDim.new(0, math.max(0, baseCorner - inset))
    end

    local maskSize = (STATE._menuSweepMask and STATE._menuSweepMask.AbsoluteSize) or layer.AbsoluteSize
    local layerSize = maskSize
    local width = math.max(120, layerSize.X)
    local height = math.max(120, layerSize.Y)
    local diagonal = math.ceil(math.sqrt(width * width + height * height))
    local glowWidth = math.max(84, math.floor(width * 0.18))
    local coreWidth = math.max(24, math.floor(glowWidth * 0.34))
    local travelPadding = math.ceil(glowWidth * 1.35)

    STATE._menuSweepTravelStart = -travelPadding
    STATE._menuSweepTravelEnd = width + travelPadding

    if STATE._menuSweepGlow then
        STATE._menuSweepGlow.Size = UDim2.fromOffset(glowWidth, diagonal)
        STATE._menuSweepGlow.Position = UDim2.fromOffset(STATE._menuSweepTravelStart, math.floor(height * 0.5))
    end
    if STATE._menuSweepCore then
        STATE._menuSweepCore.Size = UDim2.fromOffset(coreWidth, math.max(80, diagonal - 28))
        STATE._menuSweepCore.Position = UDim2.fromOffset(STATE._menuSweepTravelStart, math.floor(height * 0.5))
    end
end

