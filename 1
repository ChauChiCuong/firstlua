-- ============================================================
local orbitTracked   = {}
local orbitScanTimer = 0
local orbitWorkspaceRootParts = {}
local orbitWorkspaceRootRefresh = 0
local orbitSeenParts = {}
local function orbitClearPart(part)
    if orbitTracked[part] then
        pcall(function() part.LocalTransparencyModifier = 0 end)
        orbitTracked[part] = nil
    end
end
local function orbitTrackPart(part, rootPos)
    orbitSeenParts[part] = true
    local dx = part.Position.X - rootPos.X
    local dz = part.Position.Z - rootPos.Z
    local flatDistSq = dx * dx + dz * dz
    if flatDistSq < 144 and flatDistSq > 0.25 then
        local angle = math.atan2(dz, dx)
        local entry = orbitTracked[part]
        if entry then
            local dA = math.abs(angle - entry.prevAngle)
            if dA > math.pi then dA = (2 * math.pi) - dA end
            if dA > 0.08 then
                entry.count = entry.count + 1
                if entry.count >= 3 then
                    pcall(function() part.LocalTransparencyModifier = 1 end)
                end
            end
            entry.prevAngle = angle
        else
            orbitTracked[part] = {prevAngle = angle, count = 0}
        end
    else
        orbitClearPart(part)
    end
end
bindTracked(RunService.Heartbeat, function(dt)
    if not STATE.antiItemOrbit then
        if next(orbitTracked) then
            for part in pairs(orbitTracked) do
                pcall(function() part.LocalTransparencyModifier = 0 end)
            end
            orbitTracked = {}
        end
        return
    end
    orbitScanTimer = orbitScanTimer + dt
    if orbitScanTimer < 0.6 then return end
    orbitScanTimer = 0
    table.clear(orbitSeenParts)
    local myChar = getChar()
    local myRoot = getHRP()
    local now = tick()
    if now >= orbitWorkspaceRootRefresh then
        orbitWorkspaceRootRefresh = now + 1.5
        table.clear(orbitWorkspaceRootParts)
        local wsChildren = Workspace:GetChildren()
        -- On huge maps, scanning root workspace parts per player is expensive.
        -- Keep character-part detection and skip root scan when child count is too high.
        if #wsChildren <= 1200 then
            for _, obj in ipairs(wsChildren) do
                if obj:IsA("BasePart") and obj.Parent ~= myChar then
                    orbitWorkspaceRootParts[#orbitWorkspaceRootParts + 1] = obj
                end
            end
        end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr then
            local c = p.Character
            if c then
                local root = c:FindFirstChild("HumanoidRootPart")
                if root then
                    local rPos = root.Position
                    if (not myRoot) or ((rPos - myRoot.Position).Magnitude <= 250) then
                        for _, obj in ipairs(c:GetDescendants()) do
                            if obj:IsA("BasePart") and obj ~= root then
                                orbitTrackPart(obj, rPos)
                            end
                        end
                        for _, obj in ipairs(orbitWorkspaceRootParts) do
                            local d = obj.Position - rPos
                            if (d.X * d.X + d.Y * d.Y + d.Z * d.Z) < 144 then
                                orbitTrackPart(obj, rPos)
                            end
                        end
                    end
                end
            end
        end
    end
    for part in pairs(orbitTracked) do
        if (not orbitSeenParts[part]) or (not part) or (not part.Parent) then
            orbitClearPart(part)
        end
    end
end)
