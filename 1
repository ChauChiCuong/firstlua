-- ========================
--   SAVE KEY STORAGE
-- ========================
local SAVE_FILE = "COL_BigHead_Settings.json"

local function readSaveStore()
    if type(isfile) ~= "function" or type(readfile) ~= "function" then
        return {}
    end
    if not isfile(SAVE_FILE) then
        return {}
    end
    local okRead, raw = pcall(readfile, SAVE_FILE)
    if not okRead or type(raw) ~= "string" or raw == "" then
        return {}
    end
    local okDecode, decoded = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if okDecode and type(decoded) == "table" then
        return decoded
    end
    return {}
end

local function writeSaveStore(store)
    if type(writefile) ~= "function" then
        return false
    end
    local okEncode, encoded = pcall(function()
        return HttpService:JSONEncode(store)
    end)
    if not okEncode then
        return false
    end
    local okWrite = pcall(writefile, SAVE_FILE, encoded)
    return okWrite
end

