    stripFrom(game:GetService("Lighting"))
    stripFrom(Workspace.CurrentCamera)
    -- Also disable any added after
    if STATE._screenFxConn then
        STATE._screenFxConn:Disconnect()
        STATE._screenFxConn = nil
