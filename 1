local COLLAPSED_GLITCH_POOL = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@$%#&*"
local collapsedFxBasePos = collapsedFxLabel.Position
local collapsedBtnBaseSize = collapsedBtn.Size
local collapsedFxConn = nil
local collapsedHovering = false
local function collapsedRandomGlyph()
    local i = math.random(1, #COLLAPSED_GLITCH_POOL)
    return COLLAPSED_GLITCH_POOL:sub(i, i)
end
local function buildCollapsedGlitchText(realText, revealRatio)
    local out = table.create(#realText)
    for i = 1, #realText do
        local c = realText:sub(i, i)
        local p = i / math.max(#realText, 1)
        local revealThisChar = p <= revealRatio and math.random() > 0.2
        out[i] = revealThisChar and c or collapsedRandomGlyph()
    end
    return table.concat(out)
end
local function startCollapsedButtonFx()
    if collapsedFxConn then
        collapsedFxConn:Disconnect()
        collapsedFxConn = nil
    end
    local normal = Color3.fromRGB(235, 248, 255)
    local accent = Color3.fromRGB(0, 245, 255)
    collapsedFxConn = RunService.RenderStepped:Connect(function()
        if not collapsedBtn.Parent or not collapsedFxLabel.Parent then
            if collapsedFxConn then
                collapsedFxConn:Disconnect()
                collapsedFxConn = nil
            end
            return
        end
        local t = tick() * 3.1
        local revealRatio = 0.58 + math.sin(t) * 0.26
        local glowAlpha = 0.4 + math.sin(t * 1.7) * 0.2
        local bgBase = collapsedHovering and Color3.fromRGB(24, 28, 28) or Color3.fromRGB(0, 0, 0)
        collapsedBtn.BackgroundColor3 = bgBase:Lerp(Color3.fromRGB(0, 75, 82), math.clamp(glowAlpha, 0.12, 0.7))
        collapsedStroke.Color = Color3.fromRGB(110, 250, 255):Lerp(Color3.fromRGB(0, 190, 210), 0.5 + math.sin(t * 2.2) * 0.2)
        collapsedStroke.Thickness = 4.8 + math.sin(t * 2.8) * 0.7
        collapsedFxLabel.Visible = true
        collapsedFxLabel.Text = buildCollapsedGlitchText("COL", revealRatio)
        collapsedFxLabel.TextColor3 = normal:Lerp(accent, 0.36 + math.sin(t * 1.8) * 0.18)
        collapsedFxStroke.Transparency = 0.12 + (math.sin(t * 2.7) + 1) * 0.16
        collapsedFxLabel.Position = UDim2.new(
            collapsedFxBasePos.X.Scale,
            collapsedFxBasePos.X.Offset + math.random(-1, 1),
            collapsedFxBasePos.Y.Scale,
            collapsedFxBasePos.Y.Offset + math.random(-1, 1)
        )
        collapsedBtn.Size = UDim2.new(
            collapsedBtnBaseSize.X.Scale,
            collapsedBtnBaseSize.X.Offset,
            collapsedBtnBaseSize.Y.Scale,
            collapsedBtnBaseSize.Y.Offset + math.floor(math.sin(t * 2) * 1)
        )
    end)
end
