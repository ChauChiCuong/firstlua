local function flattenHistoryLines(value)
    if type(value) ~= "table" then return nil end
    local lines = {}
    for _, item in ipairs(value) do
        if type(item) == "string" then
            lines[#lines + 1] = item
        end
    end
    if #lines == 0 then return nil end
    return table.concat(lines, "\n")
end

local function resolveRemoteHistoryText(value, lang)
    if type(value) == "string" then
        return value
    end
    if type(value) ~= "table" then
        return nil
    end

    local direct = value[lang] or value.en or value.vi or value.jp
    if type(direct) == "string" then
        return direct
    end

    local nestedKeys = {"updateHistory", "history", "popupHistory", "content", "text", "body", "data"}
    for _, key in ipairs(nestedKeys) do
        local nested = value[key]
        if type(nested) == "string" then
            return nested
        end
        if type(nested) == "table" then
            local nestedText = resolveRemoteHistoryText(nested, lang)
            if nestedText then
                return nestedText
            end
            local flattened = flattenHistoryLines(nested)
            if flattened then
                return flattened
            end
        end
    end

    return flattenHistoryLines(value)
end

local function getUpdateHistoryText(lang)
    if not remoteUpdateHistoryLoaded then
        remoteUpdateHistoryLoaded = true
        local okFetch, rawText = pcall(function()
            return game:HttpGet(UPDATE_HISTORY_SOURCE_URL)
        end)
        if okFetch and type(rawText) == "string" and rawText ~= "" then
            remoteUpdateHistoryRawText = rawText
            local okLoad, chunk = pcall(function()
                return loadstring(rawText)
            end)
            if okLoad and type(chunk) == "function" then
                local okResult, result = pcall(chunk)
                if okResult then
                    remoteUpdateHistoryData = result
                end
            end
        end
    end

    local remoteText = resolveRemoteHistoryText(remoteUpdateHistoryData, lang)
    if type(remoteText) == "string" and remoteText ~= "" then
        return remoteText
    end
    if type(remoteUpdateHistoryRawText) == "string" and remoteUpdateHistoryRawText ~= "" then
        return remoteUpdateHistoryRawText
    end
    return getFallbackUpdateText(lang)
end

