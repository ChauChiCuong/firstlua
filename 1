do
    function STATE._chColor(r, g, b)
        return Color3.fromRGB(math.clamp(r or 0, 0, 255), math.clamp(g or 0, 0, 255), math.clamp(b or 0, 0, 255))
    end
    function STATE._chAimPoint()
        local vp = Camera.ViewportSize
        local x = vp.X * 0.5
        local y = vp.Y * 0.5
        if STATE.crosshairShowCross then
            return x + (STATE.crossOffsetX or 0), y + (STATE.crossOffsetY or 0)
        elseif STATE.crosshairShowDot then
            return x + (STATE.dotOffsetX or 0), y + (STATE.dotOffsetY or 0)
        elseif STATE.crosshairShowFOVRing then
            return x + (STATE.fovRingOffsetX or 0), y + (STATE.fovRingOffsetY or 0)
        end
        return x, y
    end
    STATE._chEnemyCacheUntil = STATE._chEnemyCacheUntil or 0
    STATE._chEnemyCached = STATE._chEnemyCached or nil
    function STATE._chEnemyAtCrosshair(forceRefresh)
        local now = tick()
        local shouldDetect =
            (STATE.crosshairEnabled and (STATE.dotEnemyColorEnabled or STATE.crossEnemyColorEnabled or STATE.fovRingEnemyColorEnabled))
            or (STATE.xMarkEnabled and (STATE._chHoldMouse or STATE._chHoldTouch))

        if not forceRefresh then
            if not shouldDetect then
                STATE._chEnemyCached = nil
                STATE._chEnemyCacheUntil = 0
                return nil
            end
            if (STATE._chEnemyCacheUntil or 0) > now then
                return STATE._chEnemyCached
            end
        end

        STATE._chEnemyCacheUntil = now + 0.06
        local x, y = STATE._chAimPoint()
        local ray = Camera:ViewportPointToRay(x, y)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {getChar(), Camera}
        local hit = Workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
        local part = hit and hit.Instance or mouse.Target
        local cur = part
        while cur and cur ~= Workspace do
            if cur:IsA("Model") then
                local hum = cur:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local owner = Players:GetPlayerFromCharacter(cur)
                    if owner == nil then
                        STATE._chEnemyCached = cur
                        return cur
                    end
                    if owner ~= plr and (not owner.Team or not plr.Team or owner.Team ~= plr.Team) then
                        STATE._chEnemyCached = cur
                        return cur
                    end
                    STATE._chEnemyCached = nil
                    return nil
                end
            end
            cur = cur.Parent
        end
        STATE._chEnemyCached = nil
        return nil
    end

