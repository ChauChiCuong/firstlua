-- ========================
--   BIGHEAD FUNCTIONALITY
--   (from headshot.lua)
-- ========================

-- Optimized cache: no full player scan on each frame
local trackedModels = {}
local trackedHeads = {}
local headStateCache = {}
local modelFxStateCache = {}
local playerConnMap = {}
local wasBigHeadEnabled = false

local UPDATE_INTERVAL = 0.12
local FX_SCAN_INTERVAL = 1
local updateAccumulator = 0
local fxScanAccumulator = 0

local function isValidTargetModel(model)
    if not model or not model:IsA("Model") then return false end
    local owner = Players:GetPlayerFromCharacter(model)
    if owner == localPlayer then return false end
    if not model:FindFirstChildOfClass("Humanoid") then return false end
    if owner then return true end
    return model:FindFirstChild("Head") ~= nil
end

local function cacheHeadState(head)
    if headStateCache[head] then return headStateCache[head] end
    local st = {
        size = head.Size,
        transparency = head.Transparency,
        canCollide = head.CanCollide,
        massless = head.Massless,
        localTransparencyModifier = nil,
        decalTransparency = {},
    }
    pcall(function()
        st.localTransparencyModifier = head.LocalTransparencyModifier
    end)
    for _, child in ipairs(head:GetChildren()) do
        if child:IsA("Decal") or child:IsA("Texture") then
            st.decalTransparency[child] = child.Transparency
        end
    end
    headStateCache[head] = st
    return st
end

local function captureModelFxState(model, obj)
    local modelState = modelFxStateCache[model]
    if not modelState then
        modelState = {}
        modelFxStateCache[model] = modelState
    end
    if modelState[obj] then return modelState[obj] end

    local rec = nil
    if obj:IsA("Highlight") then
        rec = {
            class = "Highlight",
            enabled = obj.Enabled,
            fillTransparency = obj.FillTransparency,
            outlineTransparency = obj.OutlineTransparency,
        }
    elseif obj:IsA("SelectionBox") then
        rec = {
            class = "SelectionBox",
            visible = obj.Visible,
            lineThickness = obj.LineThickness,
            surfaceTransparency = obj.SurfaceTransparency,
        }
    end

    if rec then
        modelState[obj] = rec
    end
    return rec
end

local function hideModelFx(model)
    for _, obj in ipairs(model:GetDescendants()) do
        if obj:IsA("Highlight") then
            captureModelFxState(model, obj)
            if obj.Enabled then
                obj.Enabled = false
            end
            if obj.FillTransparency < 1 then
                obj.FillTransparency = 1
            end
            if obj.OutlineTransparency < 1 then
                obj.OutlineTransparency = 1
            end
        elseif obj:IsA("SelectionBox") then
            captureModelFxState(model, obj)
            if obj.Visible then
                obj.Visible = false
            end
            if obj.LineThickness ~= 0 then
                obj.LineThickness = 0
            end
            if obj.SurfaceTransparency < 1 then
                obj.SurfaceTransparency = 1
            end
        end
    end
end

local function applyBigHeadToModel(model, size)
    if not model or not model.Parent then return end
    local head = trackedHeads[model]
    if not head or not head.Parent then
        local found = model:FindFirstChild("Head")
        if not found or not found:IsA("BasePart") then
            trackedHeads[model] = nil
            return
        end
        head = found
        trackedHeads[model] = head
    end

    local st = cacheHeadState(head)
    local targetSize = Vector3.new(size, size, size)
    pcall(function()
        if head.Size ~= targetSize then
            head.Size = targetSize
        end
        if head.Transparency ~= 1 then
            head.Transparency = 1
        end
        pcall(function()
            if head.LocalTransparencyModifier ~= 1 then
                head.LocalTransparencyModifier = 1
            end
        end)
        head.CanCollide = false
        head.Massless = true
    end)

    -- Hide classic face and any other face/texture decal
    for _, child in ipairs(head:GetChildren()) do
        if child:IsA("Decal") or child:IsA("Texture") then
            if st.decalTransparency[child] == nil then
                st.decalTransparency[child] = child.Transparency
            end
            if child.Transparency < 1 then
                child.Transparency = 1
            end
        end
    end
end

local function restoreModel(model)
    local head = trackedHeads[model]
    local st = head and headStateCache[head]
    if head and st and head.Parent then
        pcall(function()
            head.Size = st.size
            head.Transparency = st.transparency
            head.CanCollide = st.canCollide
            head.Massless = st.massless
            if st.localTransparencyModifier ~= nil then
                head.LocalTransparencyModifier = st.localTransparencyModifier
            end
        end)
        for child, tr in pairs(st.decalTransparency) do
            if child and child.Parent then
                pcall(function()
                    child.Transparency = tr
                end)
            end
        end
    end
    if head then
        headStateCache[head] = nil
    end

    local modelFx = modelFxStateCache[model]
    if modelFx then
        for obj, rec in pairs(modelFx) do
            if obj and obj.Parent and rec then
                pcall(function()
                    if rec.class == "Highlight" then
                        obj.Enabled = rec.enabled
                        obj.FillTransparency = rec.fillTransparency
                        obj.OutlineTransparency = rec.outlineTransparency
                    elseif rec.class == "SelectionBox" then
                        obj.Visible = rec.visible
                        obj.LineThickness = rec.lineThickness
                        obj.SurfaceTransparency = rec.surfaceTransparency
                    end
                end)
            end
        end
        modelFxStateCache[model] = nil
    end
end

local function addTrackedModel(model)
    if not isValidTargetModel(model) then return end
    trackedModels[model] = true
    local head = model:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        trackedHeads[model] = head
    end
end

local function removeTrackedModel(model)
    if trackedModels[model] then
        restoreModel(model)
    end
    trackedModels[model] = nil
    trackedHeads[model] = nil
    modelFxStateCache[model] = nil
end

local function hookPlayer(player)
    if player == localPlayer then return end
    local conns = {}
    conns[#conns + 1] = player.CharacterAdded:Connect(function(character)
        addTrackedModel(character)
    end)
    conns[#conns + 1] = player.CharacterRemoving:Connect(function(character)
        removeTrackedModel(character)
    end)
    playerConnMap[player] = conns

    if player.Character then
        addTrackedModel(player.Character)
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    hookPlayer(p)
end

Players.PlayerAdded:Connect(function(p)
    hookPlayer(p)
end)

Players.PlayerRemoving:Connect(function(p)
    local conns = playerConnMap[p]
    if conns then
        for _, c in ipairs(conns) do
            c:Disconnect()
        end
        playerConnMap[p] = nil
    end
    if p.Character then
        removeTrackedModel(p.Character)
    end
end)

for _, obj in ipairs(workspace:GetDescendants()) do
    if obj:IsA("Model") then
        addTrackedModel(obj)
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Model") then
        addTrackedModel(obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("Model") then
        removeTrackedModel(obj)
    end
end)

RunService.Heartbeat:Connect(function(dt)
    if not _G.BigHeadEnabled then
        if wasBigHeadEnabled then
            for model in pairs(trackedModels) do
                restoreModel(model)
            end
            wasBigHeadEnabled = false
        end
        return
    end

    wasBigHeadEnabled = true
    updateAccumulator = updateAccumulator + dt
    fxScanAccumulator = fxScanAccumulator + dt
    if updateAccumulator < UPDATE_INTERVAL then
        return
    end
    updateAccumulator = 0

    local size = math.clamp(tonumber(_G.BigHeadSize) or 2, 2, 14)
    local shouldScanFx = fxScanAccumulator >= FX_SCAN_INTERVAL
    if shouldScanFx then
        fxScanAccumulator = 0
    end

    for model in pairs(trackedModels) do
        if model and model.Parent then
            applyBigHeadToModel(model, size)
            if shouldScanFx then
                hideModelFx(model)
            end
        else
            removeTrackedModel(model)
        end
    end
end)
