local function normalizeIdText(value)
    if type(value) == "number" then
        return string.format("%.0f", value)
    end
    if type(value) == "string" then
        local clean = value:match("^%s*(.-)%s*$")
        if clean and clean:match("^%d+$") then
            return clean
        end
    end
    return nil
end

