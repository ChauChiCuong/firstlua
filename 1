-- ========================
--   SLIDER LOGIC
-- ========================
local SLIDER_MIN  = 2
local SLIDER_MAX  = 14

local function updateSlider(value)
    value = math.clamp(math.floor(value + 0.5), SLIDER_MIN, SLIDER_MAX)
    _G.BigHeadSize       = value
    local t              = (value - SLIDER_MIN) / (SLIDER_MAX - SLIDER_MIN)
    sliderFill.Size      = UDim2.new(t, 0, 1, 0)
    sliderKnob.Position  = UDim2.new(t, 0, 0.5, 0)
    sizeLabel.Text       = "Head Size:  " .. value
end

updateSlider(_G.BigHeadSize or 2)

local sliderDragging = false
local sliderDragInput = nil

local function updateSliderFromInputPosition(positionX)
    local abs = sliderTrack.AbsolutePosition
    local sz  = sliderTrack.AbsoluteSize
    local t   = math.clamp((positionX - abs.X) / sz.X, 0, 1)
    updateSlider(SLIDER_MIN + t * (SLIDER_MAX - SLIDER_MIN))
end

sliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        sliderDragInput = input
        updateSliderFromInputPosition(input.Position.X)
    end
end)

sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        sliderDragInput = input
        updateSliderFromInputPosition(input.Position.X)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == sliderDragInput
        or input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch
    then
        sliderDragging = false
        sliderDragInput = nil
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not sliderDragging then
        return
    end

    local isMouseMove = input.UserInputType == Enum.UserInputType.MouseMovement
    local isTouchMove = input.UserInputType == Enum.UserInputType.Touch
    if isMouseMove or (isTouchMove and input == sliderDragInput) then
        updateSliderFromInputPosition(input.Position.X)
    end
end)

