        STATE._collapsedFxAccum = (STATE._collapsedFxAccum or 0) + (dt or 0)
        if STATE._collapsedFxAccum < (1 / 24) then return end
        dt = STATE._collapsedFxAccum
        STATE._collapsedFxAccum = 0
        local t = tick() * 3.1
        local revealRatio = 0.58 + math.sin(t) * 0.26
        local glowAlpha = 0.4 + math.sin(t * 1.7) * 0.2
        local bgBase = STATE._collapsedHovering and STATE._THEME.smallBtnHoverBg or STATE._THEME.smallBtnBg
        STATE._collapsedBtn.BackgroundColor3 = bgBase:Lerp(STATE._THEME.fxDeep, math.clamp(glowAlpha, 0.12, 0.7))
        STATE._collapsedBtn.BackgroundTransparency = MENU_DARK_TRANSPARENCY
        STATE._collapsedStroke.Color = STATE._THEME.fxSoft:Lerp(STATE._THEME.fxDeep, 0.5 + math.sin(t * 2.2) * 0.2)
        STATE._collapsedStroke.Thickness = 4.8 + math.sin(t * 2.8) * 0.7
        STATE._collapsedFxLabel.Visible = true
        STATE._collapsedFxLabel.Text = STATE._buildCollapsedGlitchText("COL", revealRatio)
        STATE._collapsedFxLabel.TextColor3 = normal:Lerp(accent, 0.36 + math.sin(t * 1.8) * 0.18)
        STATE._collapsedFxStroke.Transparency = 0.12 + (math.sin(t * 2.7) + 1) * 0.16
        STATE._collapsedFxLabel.Position = UDim2.new(
            STATE._collapsedFxBasePos.X.Scale,
            STATE._collapsedFxBasePos.X.Offset + math.random(-1, 1),
            STATE._collapsedFxBasePos.Y.Scale,
            STATE._collapsedFxBasePos.Y.Offset + math.random(-1, 1)
        )
        STATE._collapsedBtn.Size = UDim2.new(
            STATE._collapsedBtnBaseSize.X.Scale,
            STATE._collapsedBtnBaseSize.X.Offset,
            STATE._collapsedBtnBaseSize.Y.Scale,
            STATE._collapsedBtnBaseSize.Y.Offset + math.floor(math.sin(t * 2) * 1)
        )
    end)
end

