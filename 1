    STATE._screenFxConn = game:GetService("Lighting").DescendantAdded:Connect(function(obj)
        if STATE.noScreenFX and isFXType(obj) then
            task.wait()
            obj.Enabled = false
            table.insert(removedFX, obj)
        end
    end)
end
local function restoreScreenFX()
    if STATE._screenFxConn then
        STATE._screenFxConn:Disconnect()
        STATE._screenFxConn = nil
