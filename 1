function STATE._addChatMsg(name, msg, mine, tag, msgId)
    if msgId and STATE._chatSeenIds[msgId] then return end
    if msgId then STATE._chatSeenIds[msgId] = true end
    table.insert(STATE._chatLog, {
        name = name,
        msg  = msg,
        time = os.date("%H:%M"),
        mine = mine,
        tag  = tag or "",
        id   = msgId,
    })
    while #STATE._chatLog > STATE._maxChat do table.remove(STATE._chatLog, 1) end
    if STATE._refreshChat then STATE._refreshChat() end
    if not mine and STATE._activeTab ~= "Chat" then
        local nTag = (tag and #tag > 0) and (" [" .. tag .. "]") or ""
        notify("CuongOutLook Chat", name .. nTag .. ": " .. msg, 4)
    end
end

function STATE._chatTryBindRelay()
    local rs = game:GetService("ReplicatedStorage")
    local relay = rs:FindFirstChild(STATE._chatRelayName)
    if relay and relay:IsA("RemoteEvent") then
        STATE._chatRelay = relay
        if not STATE._chatRelayBound then
            STATE._chatRelayBound = true
            relay.OnClientEvent:Connect(function(payload)
                if type(payload) ~= "table" then return end
                if payload.kind ~= "COL_CHAT_RECV" then return end
                if type(payload.msg) ~= "string" or #payload.msg == 0 then return end

                local fromId = tonumber(payload.fromUserId) or 0
                local toId   = tonumber(payload.toUserId) or 0
                local mine   = (fromId == plr.UserId)

                if toId ~= 0 and toId ~= plr.UserId and not mine then
                    return
                end

                local fromName = tostring(payload.fromName or ("User" .. tostring(fromId)))
                local tag = ""
                if toId ~= 0 then
                    if mine then
                        tag = "to " .. tostring(payload.toName or tostring(toId))
                    else
                        tag = "whisper"
                    end
                else
                    tag = "all"
                end
                STATE._addChatMsg(fromName, payload.msg, mine, tag, payload.id)
            end)
        end
        return true
    end
    return false
end

if not STATE._chatRelayScanBound then
    STATE._chatRelayScanBound = true
    game:GetService("ReplicatedStorage").ChildAdded:Connect(function(obj)
        if obj and obj.Name == STATE._chatRelayName then
            task.wait()
            pcall(function() STATE._chatTryBindRelay() end)
        end
    end)
end
pcall(function() STATE._chatTryBindRelay() end)

function STATE._chatSend(msg)
    if not msg or #msg == 0 or #msg > 150 then return end
    local target = STATE._chatTarget
    local toId = (target and target.Parent and target.UserId) or 0
    local toName = (toId ~= 0 and target and target.Name) or nil
    local msgId = tostring(plr.UserId) .. "_" .. tostring(math.floor(tick() * 1000)) .. "_" .. tostring(math.random(100, 999))
    local tag = (toId == 0) and "all" or ("to " .. tostring(toName or toId))

    if STATE._chatUseShared then
        pcall(function() STATE._chatTryBindRelay() end)
    end

    if STATE._chatUseShared and STATE._chatRelay then
        local ok = pcall(function()
            STATE._chatRelay:FireServer({
                kind = "COL_CHAT_SEND",
                id = msgId,
                msg = msg,
                toUserId = toId,
            })
        end)
        if ok then
            STATE._addChatMsg(plr.Name, msg, true, tag, msgId)
            return
        end
    end

    -- Fallback local-only
    STATE._addChatMsg(plr.Name, msg, true, "local", msgId)
end

