local mobileTouchCount = 0
local mobileTouchMoveAt = 0
local mobileTouchMoveMag = 0
local mobileTouchReleasedAt = 0
bindTracked(UserInputService.InputBegan, function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        mobileTouchCount = mobileTouchCount + 1
        mobileTouchMoveAt = tick()
        mobileTouchMoveMag = 0
    end
end)
bindTracked(UserInputService.InputChanged, function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        mobileTouchMoveAt = tick()
        local delta = input.Delta
        if typeof(delta) == "Vector3" then
            mobileTouchMoveMag = Vector2.new(delta.X, delta.Y).Magnitude
        elseif typeof(delta) == "Vector2" then
            mobileTouchMoveMag = delta.Magnitude
        else
            mobileTouchMoveMag = 0
        end
    end
end)
bindTracked(UserInputService.InputEnded, function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        mobileTouchCount = math.max(0, mobileTouchCount - 1)
        mobileTouchMoveAt = tick()
        mobileTouchReleasedAt = tick()
        if mobileTouchCount == 0 then
            mobileTouchMoveMag = 0
        end
    end
end)
