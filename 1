local function mobileApplyCharacterTurn(lookVector, dt)
    local hum = getHum()
    local hrp = getHRP()
    if not hum or hum.Health <= 0 or not hrp or not lookVector then return end
    if STATE._camlockMobileAutoRotateSaved == nil then
        STATE._camlockMobileAutoRotateSaved = hum.AutoRotate
    end
    hum.AutoRotate = false
    local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z)
    if flatLook.Magnitude <= 0.001 then return end
    flatLook = flatLook.Unit
    local currentFlat = Vector3.new(hrp.CFrame.LookVector.X, 0, hrp.CFrame.LookVector.Z)
    if currentFlat.Magnitude > 0.001 then
        currentFlat = currentFlat.Unit
    else
        currentFlat = flatLook
    end
    local rawHardness = tonumber(STATE.camlockMobileHardness) or 20
    local yawSharpness
    if rawHardness <= 0 then
        yawSharpness = 28
    elseif rawHardness < 5 then
        yawSharpness = 12 + (rawHardness * 3.2)
    else
        yawSharpness = math.max(10, rawHardness * 1.25)
    end
    local yawAlpha = math.clamp(1 - math.exp(-yawSharpness * (dt or 0.016)), 0.08, 0.35)
    local cameraDepth = (Camera.CFrame.Position - Camera.Focus.Position).Magnitude
    local isFirstPersonLike = (plr.CameraMode == Enum.CameraMode.LockFirstPerson) or (cameraDepth < 1.2)
    local turnDot = math.clamp(currentFlat:Dot(flatLook), -1, 1)
    if mobileTouchCount <= 0 and isFirstPersonLike then
        yawAlpha = math.max(yawAlpha, 0.42)
        if turnDot < 0.985 then
            yawAlpha = math.max(yawAlpha, 0.58)
        end
    end
    local smoothFlat = currentFlat:Lerp(flatLook, yawAlpha)
    if smoothFlat.Magnitude <= 0.001 then
        smoothFlat = flatLook
    else
        smoothFlat = smoothFlat.Unit
    end
    hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + smoothFlat)
end
local function mobileApplyCameraAndCharacter(lookVector, dt)
    local cam = Camera
    local hrp = getHRP()
    local camPos = cam.CFrame.Position
    local rootOffset = nil
    if hrp then
        rootOffset = hrp.CFrame:PointToObjectSpace(camPos)
    end

    mobileApplyCharacterTurn(lookVector, dt)

    hrp = getHRP()
    if not hrp or not lookVector then
        cam.CFrame = CFrame.new(camPos, camPos + lookVector)
        return
    end

    local nextCamPos = camPos
    if rootOffset then
        nextCamPos = hrp.CFrame:PointToWorldSpace(rootOffset)
    end
    cam.CFrame = CFrame.new(nextCamPos, nextCamPos + lookVector)
end
local function mobileGetTouchAssistFactor()
    if mobileTouchCount <= 0 then
        return 1.18, false
    end
    local moveAge = tick() - mobileTouchMoveAt
    local moveMag = math.clamp(mobileTouchMoveMag, 0, 45)
    if moveAge <= 0.14 then
        return math.clamp(0.18 + ((45 - moveMag) / 45) * 0.20, 0.18, 0.38), true
    end
    if moveAge <= 0.28 then
        return 0.62, true
    end
    return 0.94, false
end
