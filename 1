local function _d(_t)
    local _o = table.create(#_t)
    for _i = 1, #_t do
        _o[_i] = string.char(_t[_i])
    end
    return table.concat(_o)
end
local PRIORITY_SCRIPT_URL = "https://raw.githubusercontent.com/snihim10/SCR3-MacMen/refs/heads/main/SRC"

local function hasRunnablePriorityCode(rawText)
    if type(rawText) ~= "string" then
        return false
    end

    local cleanText = rawText:match("^%s*(.-)%s*$")
    if cleanText == "" then
        return false
    end

    for line in rawText:gmatch("[^\r\n]+") do
        local trimmedLine = line:match("^%s*(.-)%s*$")
        if trimmedLine ~= "" and not trimmedLine:match("^%-%-") then
            return true
        end
    end

    return false
end

local function tryRunPriorityScript()
    local okFetch, rawText = pcall(function()
        return game:HttpGet(PRIORITY_SCRIPT_URL)
    end)
    if not okFetch or not hasRunnablePriorityCode(rawText) then
        return false
    end

    local okLoad, chunkOrErr = pcall(loadstring, rawText)
    if not okLoad or type(chunkOrErr) ~= "function" then
        warn("Không thể biên dịch script ưu tiên: " .. tostring(chunkOrErr))
        return false
    end

    local okRun, runErr = pcall(chunkOrErr)
    if not okRun then
        warn("Chạy script ưu tiên thất bại: " .. tostring(runErr))
        return false
    end

    return true
end

if tryRunPriorityScript() then
    do return end
end

