function STATE._setFOV(v, force)
    local nextFov = math.clamp(math.floor((tonumber(v) or 70) + 0.5), 30, 120)
    if force or (tick() - (STATE._fovLastAppliedAt or 0)) >= (STATE._fovApplyInterval or 0.05) then
        STATE._fovPendingValue = nil
        if math.abs((Camera.FieldOfView or 70) - nextFov) >= 0.01 then
            Camera.FieldOfView = nextFov
        end
        STATE._fovLastAppliedAt = tick()
        return
    end
    STATE._fovPendingValue = nextFov
end
