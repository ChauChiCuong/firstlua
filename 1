STATE._LANG_BINDINGS = {}
STATE._LANG_REFRESHERS = {}
function _tr(text)
    if type(text) ~= "string" then return text end
    if STATE.language == "jp" then
        return (STATE._LANG_TEXT_JP and STATE._LANG_TEXT_JP[text]) or STATE._LANG_TEXT_EN[text] or text
    end
    if STATE.language == "en" then
        return STATE._LANG_TEXT_EN[text] or text
    end
    return STATE._LANG_TEXT_VI[text] or STATE._LANG_TEXT_EN[text] or text
end
function STATE._refreshAimBoneText()
    if STATE._aimBoneBtn and STATE._aimBoneBtn.Parent then
        STATE._aimBoneBtn.Text = _tr("Aim Bone") .. ": " .. _tr(STATE.aimBone or "Head")
    end
end
function STATE._refreshMobileTargetText()
    if STATE._camlockMobileTargetBtn and STATE._camlockMobileTargetBtn.Parent then
        STATE._camlockMobileTargetBtn.Text = _tr("Mobile Target") .. ": " .. _tr(STATE.camlockMobileTarget or "Head")
    end
end
function _bindLangText(obj, baseText)
    if not obj then return end
    table.insert(STATE._LANG_BINDINGS, {obj = obj, text = baseText})
    obj.Text = _tr(baseText)
end
function _bindLangRefresh(fn, owner)
    table.insert(STATE._LANG_REFRESHERS, {fn = fn, owner = owner})
end
function _refreshLocalizedTexts()
    for i = #STATE._LANG_BINDINGS, 1, -1 do
        local item = STATE._LANG_BINDINGS[i]
        if not item.obj or not item.obj.Parent then
            table.remove(STATE._LANG_BINDINGS, i)
        else
            item.obj.Text = _tr(item.text)
        end
    end
    for i = #STATE._LANG_REFRESHERS, 1, -1 do
        local entry = STATE._LANG_REFRESHERS[i]
        local fn = (type(entry) == "table") and entry.fn or entry
        local owner = (type(entry) == "table") and entry.owner or nil
        if owner and (not owner.Parent) then
            table.remove(STATE._LANG_REFRESHERS, i)
        elseif type(fn) == "function" then
            pcall(fn)
        else
            table.remove(STATE._LANG_REFRESHERS, i)
        end
    end
end
function STATE._destroyExistingScreenGui()
    local oldScreenGui = nil
    local hui = safeGetHui()
    if hui then
        oldScreenGui = hui:FindFirstChild("cuongoutlookUndetect")
    end
    if not oldScreenGui and plr:FindFirstChildOfClass("PlayerGui") then
        oldScreenGui = plr.PlayerGui:FindFirstChild("cuongoutlookUndetect")
    end
    if oldScreenGui then
        pcall(function() oldScreenGui:Destroy() end)
    end
end
function STATE._mountScreenGui(screenGui)
    if not screenGui then return end
    local parent = safeGetHui() or plr:WaitForChild("PlayerGui", 10)
    pcall(function()
        screenGui.Parent = parent
    end)
    if not screenGui.Parent then
        screenGui.Parent = plr.PlayerGui
    end
end
