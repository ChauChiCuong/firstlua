            STATE._chXPool[#STATE._chXPool + 1] = {Drawing.new("Line"), Drawing.new("Line")}
            STATE._chInitIdx = STATE._chInitIdx + 1
        end
        STATE._chInitIdx = nil
    end

    if not STATE._chInputBound then
        STATE._chInputBound = true
        mouse.Button1Down:Connect(function()
            STATE._chHoldMouse = true
            if STATE.xMarkEnabled and STATE._chEnemyAtCrosshair() then
                STATE._chXActive[#STATE._chXActive + 1] = {createdTime = tick()}
                STATE._chLastSpawn = tick()
            end
        end)
        mouse.Button1Up:Connect(function() STATE._chHoldMouse = false end)
        UserInputService.TouchStarted:Connect(function(_, gp)
            if gp then return end
            STATE._chHoldTouch = true
            if STATE.xMarkEnabled and STATE._chEnemyAtCrosshair() then
                STATE._chXActive[#STATE._chXActive + 1] = {createdTime = tick()}
                STATE._chLastSpawn = tick()
            end
        end)
        UserInputService.TouchEnded:Connect(function() STATE._chHoldTouch = false end)
    end

    if not STATE._chRenderBound then
        STATE._chRenderBound = true
        RunService.RenderStepped:Connect(function()
            local dot = STATE._chDot
            local h = STATE._chH
            local v = STATE._chV
            local ring = STATE._chRing
            local enemy = STATE._chEnemyAtCrosshair() ~= nil
            local vp = Camera.ViewportSize
            local cx, cy = vp.X / 2, vp.Y / 2

            if not STATE.crosshairEnabled then
                dot.Visible = false; h.Visible = false; v.Visible = false; ring.Visible = false
            else
                local dotCol = (enemy and STATE.dotEnemyColorEnabled) and STATE._chColor(STATE.dotEnemyColorR, STATE.dotEnemyColorG, STATE.dotEnemyColorB) or STATE._chColor(STATE.dotColorR, STATE.dotColorG, STATE.dotColorB)
                local crossCol = (enemy and STATE.crossEnemyColorEnabled) and STATE._chColor(STATE.crossEnemyColorR, STATE.crossEnemyColorG, STATE.crossEnemyColorB) or STATE._chColor(STATE.crossColorR, STATE.crossColorG, STATE.crossColorB)
                local ringCol = (enemy and STATE.fovRingEnemyColorEnabled) and STATE._chColor(STATE.fovRingEnemyColorR, STATE.fovRingEnemyColorG, STATE.fovRingEnemyColorB) or STATE._chColor(STATE.fovRingColorR, STATE.fovRingColorG, STATE.fovRingColorB)

                if STATE.crosshairShowDot then
                    dot.Position = Vector2.new(cx + STATE.dotOffsetX, cy + STATE.dotOffsetY)
                    dot.Radius = math.max(1, STATE.dotScale)
                    dot.Filled = true
                    dot.Color = dotCol
                    dot.Thickness = STATE.dotThickness
                    dot.ZIndex = STATE.dotLayer
                    dot.Visible = true
                else
                    dot.Visible = false
                end
                if STATE.crosshairShowCross then
                    local s = math.max(1, STATE.crossScale)
                    local x = cx + STATE.crossOffsetX
                    local y = cy + STATE.crossOffsetY
                    h.From = Vector2.new(x - s, y); h.To = Vector2.new(x + s, y)
                    h.Color = crossCol; h.Thickness = STATE.crossThickness; h.ZIndex = STATE.crossLayer; h.Visible = true
                    v.From = Vector2.new(x, y - s); v.To = Vector2.new(x, y + s)
                    v.Color = crossCol; v.Thickness = STATE.crossThickness; v.ZIndex = STATE.crossLayer; v.Visible = true
                else
                    h.Visible = false; v.Visible = false
                end
                if STATE.crosshairShowFOVRing then
                    ring.Position = Vector2.new(cx + STATE.fovRingOffsetX, cy + STATE.fovRingOffsetY)
                    ring.Radius = math.max(0, STATE.fovRingScale)
                    ring.Filled = false
                    ring.Color = ringCol
                    ring.Thickness = STATE.fovRingThickness
                    ring.ZIndex = STATE.fovRingLayer
                    ring.Visible = true
                else
                    ring.Visible = false
                end
            end

            local now = tick()
            if (STATE._chHoldMouse or STATE._chHoldTouch) and STATE.xMarkEnabled and (now - STATE._chLastSpawn) >= 0.06 then
                if STATE._chEnemyAtCrosshair() then
                    STATE._chXActive[#STATE._chXActive + 1] = {createdTime = now}
                    STATE._chLastSpawn = now
                end
            end
            local idx = 1
            for i = #STATE._chXActive, 1, -1 do
                local mark = STATE._chXActive[i]
                local age = now - mark.createdTime
                if age > (STATE.xMarkDuration or 0.5) then
                    table.remove(STATE._chXActive, i)
                elseif idx <= #STATE._chXPool then
                    local fade = math.clamp(1 - (age / math.max(STATE.xMarkDuration or 0.5, 0.001)), 0, 1)
                    local pair = STATE._chXPool[idx]
                    local l1, l2 = pair[1], pair[2]
                    local s = STATE.xMarkScale or 20
                    local c = STATE._chColor(STATE.xMarkColorR, STATE.xMarkColorG, STATE.xMarkColorB)
                    local center = Vector2.new(cx, cy)
                    l1.From = center - Vector2.new(s / 2, s / 2); l1.To = center + Vector2.new(s / 2, s / 2)
                    l1.Color = c; l1.Thickness = STATE.xMarkThickness or 2; l1.Transparency = fade; l1.ZIndex = 8; l1.Visible = STATE.xMarkEnabled
                    l2.From = center - Vector2.new(s / 2, -s / 2); l2.To = center + Vector2.new(s / 2, -s / 2)
                    l2.Color = c; l2.Thickness = STATE.xMarkThickness or 2; l2.Transparency = fade; l2.ZIndex = 8; l2.Visible = STATE.xMarkEnabled
                    idx = idx + 1
                end
            end
            for i = idx, #STATE._chXPool do
                local pair = STATE._chXPool[i]
                pair[1].Visible = false
                pair[2].Visible = false
            end
        end)
    end
end
