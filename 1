        injCheckTimer2 = 0
        local workspaceFlyParts = collectWorkspaceFlyParts()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= plr then
                pcall(function() checkInjection(p, workspaceFlyParts) end)
