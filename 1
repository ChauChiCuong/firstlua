end
local function espCol(ownerPlayer)
    if ownerPlayer and STATE.espTeamCheck and ownerPlayer.Team and plr.Team and ownerPlayer.Team == plr.Team then
        return ESP_BLUE
    end
    return ESP_RED
end
local function espIsEnemyPlayer(ownerPlayer)
    if not ownerPlayer or ownerPlayer == plr then
        return false
    end
    if not ownerPlayer.Team or not plr.Team then
        -- Treat neutral/no-team targets as valid enemy targets for ESP/chams.
        return true
    end
    return ownerPlayer.Team ~= plr.Team
end
local function espShouldShowChams(ownerPlayer)
    if not STATE.espChams then
        return false
    end
    if ownerPlayer == plr then
        return false
    end
    if not ownerPlayer then
        -- NPC/config targets should still receive chams.
        return true
    end
    if not STATE.espTeamCheck then
        return true
    end
    return espIsEnemyPlayer(ownerPlayer)
end
local function espGetTrackingPart(model)
    if not model then return nil end
    local targetModel, hum = STATE._resolveTargetModel(model)
    if not targetModel then return nil end
    return (hum and hum.RootPart)
        or STATE._findPreferredBasePart(targetModel, {"HumanoidRootPart", "UpperTorso", "Torso", "LowerTorso", "Head", "head"})
        or targetModel.PrimaryPart
        or targetModel:FindFirstChildWhichIsA("BasePart", true)
end
local function espGetControlledModel(ownerPlayer)
    if not ownerPlayer or ownerPlayer == plr then return nil end
    local character = ownerPlayer.Character
    local humanoid = character and STATE._findHumanoid(character)
    local seatPart = humanoid and humanoid.SeatPart
    if not seatPart or not seatPart:IsA("BasePart") or not seatPart:IsDescendantOf(Workspace) then
        return nil
    end
    local controlledModel = nil
    local cur = seatPart.Parent
    while cur and cur ~= Workspace and cur ~= character do
        if cur:IsA("Model") then
            controlledModel = cur
        end
        cur = cur.Parent
    end
    if not controlledModel or controlledModel == character then
        return nil
