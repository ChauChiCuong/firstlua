saveBtn.Activated:Connect(function()
    activeSaveKey = "default"
    local store = readSaveStore()
    store.__lastKey = activeSaveKey
    store[activeSaveKey] = getCurrentSettings()

    if writeSaveStore(store) then
        saveBtn.Text = "Saved!"
    else
        saveBtn.Text = "No file API"
    end
    task.delay(1, function()
        if saveBtn and saveBtn.Parent then
            saveBtn.Text = "Save"
        end
    end)
end)

loadBtn.Activated:Connect(function()
    activeSaveKey = "default"
    local store = readSaveStore()
    local record = store[activeSaveKey]
