function STATE._queueScriptOnTeleport(source)
    if type(source) ~= "string" or source == "" then
        return false
    end

    local queueFns = {}
    local function addQueueFn(fn)
        if type(fn) == "function" then
            queueFns[#queueFns + 1] = fn
        end
    end

    addQueueFn(queue_on_teleport)
    addQueueFn(queueonteleport)
    if type(syn) == "table" then
        addQueueFn(syn.queue_on_teleport)
    end
    if type(fluxus) == "table" then
        addQueueFn(fluxus.queue_on_teleport)
    end

    for _, queueFn in ipairs(queueFns) do
        local ok = pcall(queueFn, source)
        if ok then
            return true
        end
    end

    return false
end
function STATE._clearSavedLoaderKey()
