function STATE._respawnMenuFlameParticle(part)
    if not part then return end
    local edgeMode = math.random(1, 3)
    local x, y, vx, vy
    if edgeMode == 1 then
        x = 0.05 + math.random() * 0.9
        y = 1.02
        vx = (math.random() - 0.5) * 0.05
        vy = -(0.18 + math.random() * 0.24)
    elseif edgeMode == 2 then
        x = 0.03 + math.random() * 0.12
        y = 0.2 + math.random() * 0.8
        vx = 0.025 + math.random() * 0.035
        vy = -(0.08 + math.random() * 0.16)
    else
        x = 0.85 + math.random() * 0.12
        y = 0.2 + math.random() * 0.8
        vx = -(0.025 + math.random() * 0.035)
        vy = -(0.08 + math.random() * 0.16)
    end

    local baseSize = math.random(10, 24)
    local baseTransparency = 0.18 + math.random() * 0.22
    part.Size = UDim2.fromOffset(baseSize, math.floor(baseSize * 1.4))
    part.Position = UDim2.fromScale(x, y)
    part.Rotation = math.random(-18, 18)
    part.BackgroundColor3 = STATE._THEME.fxFlame
    part.BackgroundTransparency = baseTransparency
    part.Visible = true

    STATE._menuFlameParticleState[part] = {
        x = x,
        y = y,
        vx = vx,
        vy = vy,
        age = 0,
        duration = 0.45 + math.random() * 0.8,
        spin = (math.random() - 0.5) * 30,
        baseSize = baseSize,
        baseTransparency = baseTransparency,
    }
end

