    end)

    if type(isfile) == "function" and type(delfile) == "function" then
        local okExists, exists = pcall(isfile, STATE._loaderSavedKeyFile)
        if okExists and exists then
            pcall(delfile, STATE._loaderSavedKeyFile)
        end
    end
end
function STATE._rejoinCurrentServer(queuedSource)
    if MOBILE_SAFE_MODE then
        queuedSource = nil
    end
    if queuedSource and not STATE._queueScriptOnTeleport(queuedSource) then
        notify(_tr("Setting"), _tr("Teleport queue is not supported by this executor."), 3)
        return false
    end

    if queuedSource then
        notify(_tr("Setting"), _tr("Queued script for next rejoin."), 2)
    end

    notify(_tr("World"), _tr("Rejoining server..."), 2)
    task.spawn(function()
        local ok = pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, plr)
        end)
        if not ok then
            pcall(function()
                TeleportService:Teleport(game.PlaceId, plr)
            end)
        end
    end)
    return true
end
