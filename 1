Act("World", "Server Hop", Color3.fromRGB(0, 170, 255), function()
    notify("World", "Searching least-populated server...", 2)
    task.spawn(function()
        local placeId = game.PlaceId
        local currentJob = game.JobId
        local chosenServerId = nil
        local bestPlaying = math.huge
        local bestFreeSlots = -1
        local cursor = ""
        for _ = 1, 8 do
            local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
            if cursor ~= "" then
                url = url .. "&cursor=" .. cursor
            end
            local okReq, body = pcall(function()
                return game:HttpGet(url)
            end)
            if not okReq or not body then break end
            local okJson, parsed = pcall(function()
                return game:GetService("HttpService"):JSONDecode(body)
            end)
            if not okJson or type(parsed) ~= "table" then break end
            local servers = parsed.data or {}
            for _, s in ipairs(servers) do
                if s and s.id and s.id ~= currentJob then
                    local playing = tonumber(s.playing) or 0
                    local maxPlayers = tonumber(s.maxPlayers) or 0
                    local freeSlots = maxPlayers - playing
                    if maxPlayers > 0 and playing < maxPlayers then
                        if playing < bestPlaying or (playing == bestPlaying and freeSlots > bestFreeSlots) then
                            bestPlaying = playing
                            bestFreeSlots = freeSlots
                            chosenServerId = s.id
                        end
                    end
                end
            end
            cursor = parsed.nextPageCursor or ""
            if cursor == "" then break end
        end
        if chosenServerId then
            notify("World", "Hopping to least-populated server...", 2)
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, chosenServerId, plr)
            end)
        else
            notify("World", "No suitable server found", 3)
        end
    end)
end)
