--   TOGGLE LOGIC
-- ========================
local function refreshToggle()
    if _G.BigHeadEnabled then
        toggleBtn.Text             = "Disable"
        toggleBtn.BackgroundColor3 = C.RED
        statusLabel.Text           = "Enable BigHead (very risky)"
        statusLabel.TextColor3     = Color3.fromRGB(46, 204, 113)
    else
        toggleBtn.Text             = "Enable"
        toggleBtn.BackgroundColor3 = C.PANEL
        statusLabel.Text           = "Enable BigHead (very risky)"
        statusLabel.TextColor3     = Color3.fromRGB(231, 76, 60)
    end
end

local function getCurrentSettings()
    return {
        enabled = _G.BigHeadEnabled == true,
        size = _G.BigHeadSize or 2,
    }
end

local function applySettings(record)
    if type(record) ~= "table" then
        return false
    end
    _G.BigHeadEnabled = record.enabled == true
    updateSlider(record.size or 2)
    refreshToggle()
    return true
end

toggleBtn.Activated:Connect(function()
    _G.BigHeadEnabled = not _G.BigHeadEnabled
    refreshToggle()
end)

