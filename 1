function STATE._startMenuFlameFx()
    if STATE.lowMenuGraphic or not STATE.cyanMenuFlame then
        STATE._stopMenuFlameFx()
        return
    end
    if STATE._menuFlameConn then
        STATE._menuFlameConn:Disconnect()
        STATE._menuFlameConn = nil
    end
    if STATE._menuFlameLayer then
        STATE._menuFlameLayer.Visible = true
    end
    if STATE._menuFlameStroke then
        STATE._menuFlameStroke.Enabled = true
    end
    for _, part in ipairs(STATE._menuFlameParticles or {}) do
        STATE._respawnMenuFlameParticle(part)
    end
    STATE._menuFlameAccum = 0
    STATE._menuFlameConn = RunService.RenderStepped:Connect(function(dt)
        if not STATE._window or not STATE._window.Parent or not STATE._menuFlameLayer or not STATE._menuFlameLayer.Parent then
            STATE._stopMenuFlameFx()
            return
        end
        if not STATE._window.Visible then
            return
        end
        STATE._menuFlameAccum = (STATE._menuFlameAccum or 0) + (dt or 0)
        if STATE._menuFlameAccum < (1 / 18) then return end
        dt = STATE._menuFlameAccum
        STATE._menuFlameAccum = 0

        local now = tick()
        local pulse = 0.5 + math.sin(now * 4.6) * 0.5
        if STATE._menuFlameStroke then
            STATE._menuFlameStroke.Color = STATE._THEME.fxFlame:Lerp(STATE._THEME.fxFlameHighlight, pulse * 0.14)
            STATE._menuFlameStroke.Transparency = 0.1 + pulse * 0.18
            STATE._menuFlameStroke.Thickness = 2.4 + pulse * 1.8
        end
        if STATE._menuBaseStroke then
            STATE._menuBaseStroke.Transparency = 0.08 + pulse * 0.2
            STATE._menuBaseStroke.Thickness = 1.5 + pulse * 0.5
        end

        for index, part in ipairs(STATE._menuFlameParticles or {}) do
            local st = STATE._menuFlameParticleState[part]
            if st then
                st.age = st.age + dt
                local lifeRatio = st.age / math.max(st.duration, 0.001)
                if lifeRatio >= 1 then
                    STATE._respawnMenuFlameParticle(part)
                else
                    st.x = st.x + st.vx * dt
                    st.y = st.y + st.vy * dt
                    part.Position = UDim2.fromScale(st.x, st.y)
                    local nextSize = math.max(4, math.floor(st.baseSize * (1 - lifeRatio * 0.55)))
                    part.Size = UDim2.fromOffset(nextSize, math.max(6, math.floor(nextSize * 1.35)))
                    part.Rotation = part.Rotation + st.spin * dt
                    part.BackgroundTransparency = math.clamp(st.baseTransparency + lifeRatio * 0.5, 0, 0.92)
                    part.BackgroundColor3 = STATE._THEME.fxFlame:Lerp(STATE._THEME.fxFlameHighlight, (math.sin(now * 5 + index) * 0.5 + 0.5) * 0.22)
                    if st.y < -0.08 or st.x < -0.08 or st.x > 1.08 then
                        STATE._respawnMenuFlameParticle(part)
                    end
                end
            end
        end
    end)
end

