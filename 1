    STATE._Sli("Visual", "X Color R", function() return STATE.xMarkColorR end, function(v) STATE.xMarkColorR = v end, 0, 255)
    STATE._Sli("Visual", "X Color G", function() return STATE.xMarkColorG end, function(v) STATE.xMarkColorG = v end, 0, 255)
