local function resolveRemoteImageAsset(url, imageFile, metaFile)
    if type(url) ~= "string" or url == "" then return nil end
    if type(imageFile) ~= "string" or imageFile == "" then return nil end

    local customAsset = getCustomAssetFunction()
    if not customAsset then return nil end

    if type(isfile) == "function" then
        local okExists, exists = pcall(isfile, imageFile)
        if okExists and exists then
            local cachedUrl = readCachedUrl(metaFile)
            if cachedUrl and cachedUrl == url then
                local okAsset, asset = pcall(customAsset, imageFile)
                if okAsset and type(asset) == "string" and asset ~= "" then
                    return asset
                end
            end
        end
    end

    if type(writefile) ~= "function" then return nil end

    local body = nil
    local requestFn = getHttpRequestFunction()
    if requestFn then
        local okRequest, response = pcall(requestFn, {
            Url = url,
            Method = "GET",
        })
        if okRequest and type(response) == "table" then
            local success = (response.Success ~= false) and ((response.StatusCode == nil) or (tonumber(response.StatusCode) or 0) < 400)
            if success and type(response.Body) == "string" and response.Body ~= "" then
                body = response.Body
            end
        end
    end

    if not body then
        local okFetch, rawBody = pcall(function()
            return game:HttpGet(url)
        end)
        if okFetch and type(rawBody) == "string" and rawBody ~= "" then
            body = rawBody
        end
    end

    if not body then return nil end

    local okWrite = pcall(writefile, imageFile, body)
    if not okWrite then return nil end
    writeCachedUrl(metaFile, url)

    local okAsset, asset = pcall(customAsset, imageFile)
    if okAsset and type(asset) == "string" and asset ~= "" then
        return asset
    end
    return nil
end
