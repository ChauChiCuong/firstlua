local function measureWrappedUpdateTextHeight(contentWidth)
    local safeWidth = math.max(contentWidth, 1)
    local measuredSize = TextService:GetTextSize(
        updateBody.Text or "",
        updateBody.TextSize,
        updateBody.Font,
        Vector2.new(safeWidth, 100000)
    )
    return math.max(measuredSize.Y + 12, updateBody.TextSize + 12)
end

local function refreshUpdateHistoryLayout()
    updateHistoryLayoutToken = updateHistoryLayoutToken + 1
    local contentWidth = updateScroll.AbsoluteSize.X - updateScroll.ScrollBarThickness - 8
    if contentWidth <= 0 then
        task.defer(refreshUpdateHistoryLayout)
        return
    end

    if not updateBody.Parent or not updateScroll.Parent then
        return
    end

    local bottomPadding = isMobileUpdateLayout and 36 or 24
    local renderedHeight = measureWrappedUpdateTextHeight(contentWidth)
    local minimumHeight = math.max(renderedHeight, updateScroll.AbsoluteSize.Y - bottomPadding)

    updateBody.Size = UDim2.new(0, contentWidth, 0, minimumHeight)
    updateScroll.CanvasSize = UDim2.new(0, 0, 0, renderedHeight + bottomPadding)
    updateScroll.CanvasPosition = Vector2.new(0, 0)
end

