local function copyToClipboard(text, label)
    local ok = pcall(function()
        if setclipboard then
            setclipboard(text)
        elseif toclipboard then
            toclipboard(text)
        else
            error("clipboard unsupported")
        end
    end)
    if ok then
        notify("Copy", (label or "Link") .. " copied", 2)
    else
        notify("Copy", "Clipboard not supported by this executor", 3)
    end
end
