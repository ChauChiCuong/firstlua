-- Chams = Highlight instance (zero per-frame cost once created)
-- ============================================================
local espData   = {}
local espContainer = nil
local ESP_RED   = themeColor("esp_enemy", Color3.fromRGB(0, 255, 255))
local ESP_BLUE  = themeColor("esp_team", Color3.fromRGB(0, 255, 255))
local function getESPContainer()
    if not espContainer or not espContainer.Parent then
        espContainer = Instance.new("Folder")
        espContainer.Name = "CuongOutLookESP"
        espContainer.Parent = Workspace
    end
