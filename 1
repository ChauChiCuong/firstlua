local function trimTextValue(value)
    if type(value) ~= "string" then return nil end
    local trimmed = value:match("^%s*(.-)%s*$")
    if trimmed == "" then return nil end
    return trimmed
end
local function parseThemeColor(value)
    local txt = trimTextValue(value)
    if not txt then return nil end
    txt = txt:gsub("^rgb%s*%(", ""):gsub("%)$", "")
    local hex = txt:match("^#?(%x%x%x%x%x%x)$")
    if hex then
        return Color3.fromRGB(tonumber(hex:sub(1, 2), 16), tonumber(hex:sub(3, 4), 16), tonumber(hex:sub(5, 6), 16))
    end
    local r, g, b = txt:match("^(%-?%d+)%s*,%s*(%-?%d+)%s*,%s*(%-?%d+)$")
    if r and g and b then
        return Color3.fromRGB(math.clamp(tonumber(r) or 0, 0, 255), math.clamp(tonumber(g) or 0, 0, 255), math.clamp(tonumber(b) or 0, 0, 255))
    end
    return nil
end
local function parseThemeConfig(rawText)
    local data = {}
    if type(rawText) ~= "string" or rawText == "" then return data end
    for line in rawText:gmatch("[^\r\n]+") do
        local clean = line:gsub("^%s+", ""):gsub("%s+$", "")
        if clean ~= "" and not clean:match("^#") and not clean:match("^%-%-") then
            local key, value = clean:match("^([%w_%.%-]+)%s*=%s*(.+)$")
            if key and value then
                data[key:lower()] = trimTextValue(value)
            end
        end
    end
    return data
end
local function resolveRemoteHeaderTitle(rawText)
    local trimmed = trimTextValue(rawText)
    if not trimmed then return nil end

    local returned = trimTextValue(trimmed:match("^return%s+(.+)$"))
    if returned then
        trimmed = returned
    end

    local tableValue = trimmed:match('title%s*=%s*"(.-)"')
        or trimmed:match("title%s*=%s*'(.-)'")
        or trimmed:match('header%s*=%s*"(.-)"')
        or trimmed:match("header%s*=%s*'(.-)'")
        or trimmed:match('text%s*=%s*"(.-)"')
        or trimmed:match("text%s*=%s*'(.-)'")
        or trimmed:match('%[%s*1%s*%]%s*=%s*"(.-)"')
        or trimmed:match("%[%s*1%s*%]%s*=%s*'(.-)'")
    if tableValue then
        return trimTextValue(tableValue)
    end

    local unquoted = trimmed:match('^"(.*)"$') or trimmed:match("^'(.*)'$")
    return trimTextValue(unquoted) or trimmed
end
